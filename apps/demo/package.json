{
	"name": "demo",
	"version": "0.1.0",
	"description": "Demo app with Rune UI components and session-based auth",
	"type": "module",
	"scripts": {
		"env:init": "tsx ../../scripts/init-env.ts --services=demo",
		"css": "tailwindcss -i src/styles.css -o dist/styles.css",
		"css:watch": "tailwindcss -i src/styles.css -o dist/styles.css --watch=always",
		"css:minify": "tailwindcss -i src/styles.css -o dist/styles.css --minify",
		"dev": "vite --host",
		"build": "tsup && pnpm run css:minify",
		"start": "node dist/index.js",
		"lint": "biome check --config-path=../.. .",
		"lint:fix": "biome check --config-path=../.. --write .",
		"format": "biome format --config-path=../.. --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"packageManager": "pnpm@10.29.3",
	"dependencies": {
		"@hono/node-server": "^1.19.11",
		"grid": "workspace:*",
		"hono": "^4.12.5",
		"rune": "workspace:*",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@hono/vite-dev-server": "^0.25.1",
		"@tailwindcss/cli": "^4.1.0",
		"@tailwindcss/vite": "^4.1.0",
		"@types/node": "^25.3.3",
		"tailwindcss": "^4.1.0",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vali": "workspace:*",
		"vite": "^8.0.0",
		"vitest": "^4.0.18"
	}
}
