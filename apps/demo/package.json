{
	"name": "demo",
	"version": "0.1.0",
	"description": "",
	"type": "module",
	"scripts": {
		"env:init": "tsx ../../scripts/init-env.ts --services=demo",
		"dev": "tsx server.ts",
		"build": "tsc --noEmit && vite build && vite build --ssr src/entry-server.tsx --outDir dist/server",
		"preview": "NODE_ENV=production node dist/server/entry-server.js",
		"start": "NODE_ENV=production tsx server.ts",
		"lint": "biome check --config-path=../.. .",
		"lint:fix": "biome check --config-path=../.. --write .",
		"format": "biome format --config-path=../.. --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"packageManager": "pnpm@10.29.3",
	"dependencies": {
		"@hono/node-server": "^1.19.11",
		"hono": "^4.12.5",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"react-router-dom": "^7.6.0",
		"rune": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@tailwindcss/vite": "^4.1.0",
		"@types/node": "^25.3.3",
		"@types/react": "^19.1.6",
		"@types/react-dom": "^19.1.6",
		"@vitejs/plugin-react": "^6.0.0",
		"tailwindcss": "^4.1.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vali": "workspace:*",
		"vite": "^8.0.0",
		"vitest": "^4.0.18"
	}
}
