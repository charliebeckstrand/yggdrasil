{
	"name": "asgard",
	"private": true,
	"packageManager": "pnpm@10.29.3",
	"pnpm": {
		"onlyBuiltDependencies": [
			"argon2"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@vitest/coverage-v8": "^4.0.18",
		"husky": "^9.1.7",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"turbo": "^2.8.14"
	},
	"scripts": {
		"prepare": "husky || true",
		"build": "turbo run build",
		"predev": "docker compose -f docker-compose.dev.yml up -d",
		"dev": "hlidskjalf",
		"test:coverage": "turbo run test:coverage",
		"lint": "biome check packages/ services/",
		"lint:fix": "biome check --write packages/ services/",
		"format": "biome format --write packages/ services/",
		"env:init": "tsx scripts/init-env.ts",
		"env:rotate": "tsx scripts/init-env.ts --rotate"
	},
	"dependencies": {
		"hlidskjalf": "0.2.3"
	}
}
