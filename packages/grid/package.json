{
	"name": "grid",
	"version": "0.1.0",
	"description": "Shared Hono service utilities — middleware, schemas, error handling, and OpenAPI config",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./dist/index.js"
		},
		"./middleware": {
			"types": "./src/entry-middleware.ts",
			"default": "./dist/middleware.js"
		},
		"./environment": {
			"types": "./src/entry-environment.ts",
			"default": "./dist/environment.js"
		},
		"./server-lifecycle": {
			"types": "./src/entry-server-lifecycle.ts",
			"default": "./dist/server-lifecycle.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "biome check --config-path=../.. .",
		"lint:fix": "biome check --config-path=../.. --write .",
		"format": "biome format --config-path=../.. --write .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"packageManager": "pnpm@10.29.3",
	"dependencies": {
		"@hono/swagger-ui": "^0.6.0",
		"@hono/zod-openapi": "^1.2.2",
		"hono": "^4.12.5",
		"skuld": "workspace:*",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/node": "^25.3.3",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
