{
	"name": "heimdall",
	"version": "0.1.0",
	"description": "JWT authentication primitives, token management, and rate limiting",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "biome check --config-path=../.. .",
		"lint:fix": "biome check --config-path=../.. --write .",
		"format": "biome format --config-path=../.. --write .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"packageManager": "pnpm@10.29.3",
	"dependencies": {
		"@node-rs/argon2": "^2.0.2",
		"grid": "workspace:*",
		"hono": "^4.12.5",
		"ms": "^2.1.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/ms": "^2.1.0",
		"@types/node": "^25.3.3",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
