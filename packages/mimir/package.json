{
  "name": "mimir",
  "version": "0.1.0",
  "description": "Shared PostgreSQL connection pool — decomposes DATABASE_URL for DigitalOcean SSL compatibility",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check --config-path=../.. .",
    "lint:fix": "biome check --config-path=../.. --write .",
    "format": "biome format --config-path=../.. --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "packageManager": "pnpm@10.29.3",
  "dependencies": {
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.11.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
