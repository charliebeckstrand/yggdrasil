{
	"name": "rune",
	"version": "0.1.0",
	"description": "Geist-inspired UI component library — components for Hono JSX and Vue with Tailwind CSS",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./dist/index.js"
		},
		"./vue": {
			"types": "./src/vue/index.ts",
			"default": "./src/vue/index.ts"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "biome check --config-path=../.. .",
		"lint:fix": "biome check --config-path=../.. --write .",
		"format": "biome format --config-path=../.. --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"packageManager": "pnpm@10.29.3",
	"dependencies": {
		"class-variance-authority": "^0.7.1",
		"hono": "^4.12.5"
	},
	"peerDependencies": {
		"vue": "^3.5.0"
	},
	"peerDependenciesMeta": {
		"vue": {
			"optional": true
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/node": "^25.3.3",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vali": "workspace:*",
		"vitest": "^4.0.18"
	}
}
