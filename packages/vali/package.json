{
	"name": "vali",
	"version": "0.1.0",
	"description": "Shared test utilities — mock factories, custom matchers, and fixtures for Vitest",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./dist/index.js"
		},
		"./matchers": {
			"types": "./src/matchers/index.ts",
			"default": "./dist/matchers.js"
		},
		"./mocks": {
			"types": "./src/mocks/index.ts",
			"default": "./dist/mocks.js"
		},
		"./fixtures": {
			"types": "./src/fixtures/index.ts",
			"default": "./dist/fixtures.js"
		},
		"./setup": {
			"types": "./src/setup.ts",
			"default": "./dist/setup.js"
		},
		"./containers": {
			"types": "./src/containers/index.ts",
			"default": "./dist/containers.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "biome check --config-path=../.. .",
		"lint:fix": "biome check --config-path=../.. --write .",
		"format": "biome format --config-path=../.. --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"packageManager": "pnpm@10.29.3",
	"dependencies": {
		"@testcontainers/postgresql": "^11.12.0",
		"hono": "^4.8.3",
		"testcontainers": "^11.12.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/node": "^25.3.3",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18",
		"zod": "^4.3.6"
	}
}
