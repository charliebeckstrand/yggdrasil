{
	"name": "heimdall",
	"port": 8000,
	"vars": {
		"DATABASE_URL": { "type": "value", "default": "postgres://heimdall:heimdall@localhost:5432/heimdall" },
		"CORS_ORIGINS": { "type": "value", "default": "http://localhost:3000" },
		"SECRET_KEY": { "type": "secret" },
		"HEIMDALL_API_KEY": { "type": "secret" },
		"ACCESS_TOKEN_EXPIRE_MINUTES": { "type": "value", "default": "30" },
		"REFRESH_TOKEN_EXPIRE_DAYS": { "type": "value", "default": "7" },
		"VIDAR_URL": { "type": "ref", "service": "vidar" },
		"VIDAR_API_KEY": { "type": "ref", "service": "vidar", "key": "VIDAR_API_KEY" }
	}
}
