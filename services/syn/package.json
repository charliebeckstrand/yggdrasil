{
  "name": "syn",
  "version": "0.1.0",
  "description": "Next.js authentication SDK — guards routes and manages sessions with Heimdall",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "packageManager": "pnpm@10.29.3",
  "dependencies": {
    "server-only": "^0.0.1"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "next-auth": "^5.0.0-beta.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
